# =============================================================================
#  InventoryFlow Pro — environment variables
#
#  Copy this file to `.env` and edit as needed.
#
#  LOCAL DOCKER  (`docker compose up`):
#      - Leave DATABASE_URL empty / unset — the backend will auto-construct
#        it from POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB and
#        connect to the bundled postgres service.
#      - VITE_API_URL=/api  →  frontend uses the same-origin nginx proxy.
#
#  PRODUCTION  (Render / Railway backend + Vercel frontend + Neon DB):
#      - Set DATABASE_URL to the managed Postgres connection string
#        (Neon, Supabase, Render Postgres, AWS RDS, etc.).
#        Format: postgresql+psycopg2://USER:PASS@HOST:5432/DB?sslmode=require
#      - Set BACKEND_CORS_ORIGINS to include your Vercel URL.
#      - In Vercel project settings, set VITE_API_URL to your backend URL
#        (e.g. https://inventoryflow-api.onrender.com/api).
# =============================================================================

# ===== Postgres (bundled, used only when DATABASE_URL is unset) =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventoryflow
POSTGRES_PORT=5432

# ===== Backend =====
# Leave DATABASE_URL UNSET for local docker — the backend auto-builds it
# from the POSTGRES_* vars above. For production, set this to your
# managed Postgres connection string.
# DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/DB?sslmode=require

SECRET_KEY=change-me-please-use-a-long-random-string
FRONTEND_URL=http://localhost:5173
# Comma-separated or JSON list of allowed CORS origins.
# Add your Vercel URL here for production.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
LOG_LEVEL=INFO
BACKEND_PORT=8000

# ===== Frontend (only used in Docker build) =====
# Relative path: frontend uses nginx proxy (no CORS).
# Absolute URL:  for Vercel-style deploys, set in Vercel env instead.
VITE_API_URL=/api
API_PROXY_PASS=http://backend:8000/api
FRONTEND_PORT=8080
